{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "menu",
      "camelcase": "menu",
      "title": "menu",
      "scope": "source.menu",
      "file-types": [
        "menu"
      ],
      "injection-regex": "^menu$",
      "class-name": "TreeSitterMenu"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Menu grammar for tree-sitter",
    "authors": [
      {
        "name": "Sebastian Klähn",
        "email": "info@sebastian-klaehn.de"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-menu"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": true,
    "swift": false,
    "zig": false
  }
}