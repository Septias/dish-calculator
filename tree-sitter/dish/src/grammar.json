{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "dish",
  "rules": {
    "source_file": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "persons_line"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SYMBOL",
            "name": "preamble_line"
          }
        },
        {
          "type": "SYMBOL",
          "name": "ingredients_section"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "CHOICE",
            "members": [
              {
                "type": "PREC",
                "value": 1,
                "content": {
                  "type": "SYMBOL",
                  "name": "ingredient_line"
                }
              },
              {
                "type": "SYMBOL",
                "name": "preamble_line"
              }
            ]
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
