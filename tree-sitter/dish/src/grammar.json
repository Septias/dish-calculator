    "integer": {
      "type": "PATTERN",
      "value": "\\d+"
    },
    "float": {
      "type": "PATTERN",
      "value": "\\d+\\.\\d+"
    },
    "unit": {
      "type": "PATTERN",
      "value": "[^\\s]+"
    },
    "text": {
      "type": "PATTERN",
      "value": "[^\\n\\r]+"
    },
    "preamble_line": {
      "type": "PATTERN",
      "value": "[^#\\-\\n\\r][^\\n\\r]*"
    }
